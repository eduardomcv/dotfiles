command = /bin/zsh
shell-integration = zsh
shell-integration-features = ssh-terminfo,ssh-env

font-family = Iosevka Term
font-style = Medium
font-size = 16

theme = Catppuccin Mocha

cursor-style = "block"
cursor-style-blink = false

window-decoration = server
window-height = 40
window-width = 130

mouse-scroll-multiplier = 0.95
confirm-close-surface = false

macos-titlebar-style = tabs
macos-option-as-alt = left

keybind = ctrl+a>c=new_tab
keybind = ctrl+a>n=next_tab
keybind = ctrl+a>p=previous_tab
keybind = ctrl+a>x=close_surface
keybind = ctrl+a>shift+x=close_tab
keybind = ctrl+a>r=prompt_surface_title

keybind = ctrl+a>e=last_tab
keybind = ctrl+a>shift+left=move_tab:-1
keybind = ctrl+a>shift+right=move_tab:1
keybind = ctrl+a>physical:one=goto_tab:1
keybind = ctrl+a>physical:two=goto_tab:2
keybind = ctrl+a>physical:three=goto_tab:3
keybind = ctrl+a>physical:four=goto_tab:4
keybind = ctrl+a>physical:five=goto_tab:5
keybind = ctrl+a>physical:six=goto_tab:6
keybind = ctrl+a>physical:seven=goto_tab:7
keybind = ctrl+a>physical:eight=goto_tab:8
keybind = ctrl+a>physical:nine=goto_tab:9
keybind = ctrl+a>physical:zero=goto_tab:10

keybind = ctrl+a>s=new_split:down
keybind = ctrl+a>v=new_split:right
keybind = ctrl+a>equal=equalize_splits

keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:down
keybind = ctrl+a>k=goto_split:up
keybind = ctrl+a>l=goto_split:right
keybind = ctrl+a>left=goto_split:left
keybind = ctrl+a>down=goto_split:bottom
keybind = ctrl+a>up=goto_split:top
keybind = ctrl+a>right=goto_split:right

keybind = ctrl+a>shift+h=resize_split:left,5
keybind = ctrl+a>shift+j=resize_split:down,5
keybind = ctrl+a>shift+k=resize_split:up,5
keybind = ctrl+a>shift+l=resize_split:right,5
keybind = ctrl+a>shift+left=resize_split:left,5
keybind = ctrl+a>shift+down=resize_split:down,5
keybind = ctrl+a>shift+up=resize_split:up,5
keybind = ctrl+a>shift+right=resize_split:right,5

# Send the literal ctrl+a
keybind = ctrl+a>a=text:\x01

