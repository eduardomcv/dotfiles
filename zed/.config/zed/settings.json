{
    "ui_font_family": ".ZedSans",
    "ui_font_size": 16,
    "buffer_font_family": "Iosevka",
    "buffer_font_size": 15.0,
    "cursor_shape": "block",
    "cursor_blink": false,
    "relative_line_numbers": "enabled",
    "theme": {
        "mode": "system",
        "light": "Catppuccin Latte",
        "dark": "Catppuccin Mocha"
    },
    "icon_theme": "Catppuccin Mocha",
    "telemetry": {
        "diagnostics": true,
        "metrics": false
    },
    "vim_mode": true,
    "vim": {
        "use_smartcase_find": true,
        "toggle_relative_line_numbers": true
    },
    "outline_panel": {
        "dock": "right"
    },
    "collaboration_panel": {
        "dock": "left"
    },
    "git_panel": {
        "tree_view": true,
        "status_style": "icon",
        "dock": "left"
    },
    "terminal": {
        "shell": {
            "program": "zsh"
        },
        "dock": "bottom"
    },
    "agent": {
        "flexible": false,
        "button": true,
        "dock": "right",
        "favorite_models": [],
        "model_parameters": []
    },
    "tabs": {
        "show_close_button": "hover",
        "file_icons": true,
        "git_status": false
    },
    "tab_bar": {
        "show": true
    },
    "title_bar": {
        "show_user_menu": true,
        "show_sign_in": false,
        "show_branch_status_icon": true
    },
    "status_bar": {
        "active_language_button": true,
        "active_encoding_button": "non_utf8"
    },
    "project_panel": {
        "dock": "left",
        "button": true
    },
    "edit_predictions": {
        "provider": "copilot"
    },
    "languages": {
        "Python": {
            "language_servers": [
                "ty",
                "ruff",
                "!basedpyright",
                "!pyright",
                "!pylsp"
            ]
        },
        "JavaScript": {
            "language_servers": [
                "vtsls",
                "eslint",
                "!typescript-language-server",
                "!tailwindcss-language-server"
            ],
            "code_actions_on_format": {
                "source.fixAll.eslint": true
            }
        },
        "TypeScript": {
            "language_servers": [
                "vtsls",
                "eslint",
                "!typescript-language-server",
                "!tailwind-language-server"
            ],
            "code_actions_on_format": {
                "source.fixAll.eslint": true
            }
        },
        "TSX": {
            "language_servers": [
                "vtsls",
                "eslint",
                "!typescript-language-server",
                "!tailwind-language-server"
            ],
            "code_actions_on_format": {
                "source.fixAll.eslint": true
            }
        }
    },
    "agent_servers": {
        "opencode": {
            "default_config_options": {
                "mode": "build",
                "effort": "high",
                "model": "github-copilot/claude-sonnet-4.6"
            },
            "favorite_config_option_values": {
                "model": ["github-copilot/claude-sonnet-4.6"]
            },
            "type": "registry"
        },
        "github-copilot-cli": {
            "type": "registry"
        }
    }
}
